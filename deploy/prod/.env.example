# Application
ENV=production
DATABASE_URL=sqlite+aiosqlite:///./db/gateway.db

# MQTT Broker
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=8883
MQTT_CA_CERTS=/mosquitto/certs/acme-v02.api.letsencrypt.org-directory/mqtt.yourdomain.com/mqtt.yourdomain.com.crt
MQTT_ADMIN_USERNAME=admin
MQTT_ADMIN_PASSWORD=change_me
MQTT_DISCOVERY_PREFIX=homeassistant

# Feature Toggles
BACKUP_ENABLED=False
GRAFANA_LOGGING_ENABLED=False

# Backblaze B2 Backups
B2_BUCKET_NAME=
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT_URL=
BACKUP_ENCRYPTION_KEY=

# Grafana Loki logging
LOKI_PUSH_URL=
LOKI_USERNAME=
LOKI_PASSWORD=

# Rate Limiting
RATE_LIMIT_READ=60/minute
RATE_LIMIT_WRITE=20/minute

# Logging
LOG_LEVEL=INFO
